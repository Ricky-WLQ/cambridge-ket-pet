# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Phase 3 Speaking — source images staging (JPEG/PNG/WebP only; manifest.json tracked)
prisma/data/speaking-photos/*.jpg
prisma/data/speaking-photos/*.jpeg
prisma/data/speaking-photos/*.png
prisma/data/speaking-photos/*.webp

# Phase 4 — Cambridge source PDFs (© UCLES, gitignored to avoid republishing)
data/raw/*.pdf
data/raw/evp-cefr.csv
