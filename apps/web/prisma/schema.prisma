// Cambridge KET / PET — Prisma schema
// Phase 1, Step 4 — Auth.js v5 (NextAuth v5) tables added.
// Future steps extend additively via new migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ExamType {
  KET
  PET
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(STUDENT)
  locale        String    @default("zh-CN")
  activatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  ownedClasses     Class[]       @relation("TeacherClasses")
  classMemberships ClassMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeacherActivationCode {
  code      String    @id
  used      Boolean   @default(false)
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Class {
  id         String    @id @default(cuid())
  name       String
  teacherId  String
  inviteCode String    @unique
  examFocus  ExamType?
  createdAt  DateTime  @default(now())

  teacher User          @relation("TeacherClasses", fields: [teacherId], references: [id])
  members ClassMember[]
}

model ClassMember {
  classId  String
  userId   String
  joinedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([classId, userId])
}

// Exam-point (考点) reference table. One row per part of each paper.
// IDs use a stable human-readable scheme: "{examType}.{paperCode}.P{part}".
// Seeded once from Cambridge-official format data in the implementation plan.
model ExamPoint {
  id            String   @id
  examType      ExamType
  paperCode     String // "RW" (KET combined) | "R" | "W" | "L" | "S"
  part          Int?
  code          String // short code e.g. "R_P1_matching"
  label         String
  descriptionZh String
  skillTags     Json
  createdAt     DateTime @default(now())

  @@unique([examType, paperCode, part])
  @@index([examType])
}

// Difficulty-point (难点) reference table. Shared across KET + PET unless
// examType is set. Seeded from the top-10 cross-exam difficulty list.
model DifficultyPoint {
  id            String    @id
  examType      ExamType? // null => applies to both KET and PET
  code          String
  label         String
  descriptionZh String
  category      String // "grammar" | "vocab" | "pronunciation" | "discourse"
  createdAt     DateTime  @default(now())

  @@index([examType])
  @@index([category])
}
