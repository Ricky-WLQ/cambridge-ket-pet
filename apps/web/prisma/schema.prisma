// Cambridge KET / PET — Prisma schema
// Phase 1, Step 11 — adds Test, TestAttempt (reading generation + attempts)
// and GenerationEvent (rate-limit counter).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============== Enums ===============

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ExamType {
  KET
  PET
}

enum TestKind {
  READING
  WRITING
  LISTENING
  SPEAKING
  VOCAB        // Phase 4 — vocabulary practice (no per-attempt row; uses VocabProgress instead)
  GRAMMAR      // Phase 4 — grammar quizzes (uses GrammarProgress instead of TestAttempt)
  MOCK_FULL
  MOCK_SECTION
}

enum AudioStatus {
  GENERATING
  READY
  FAILED
}

enum TestMode {
  PRACTICE
  MOCK
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  ABANDONED
}

enum SpeakingStatus {
  IDLE
  IN_PROGRESS
  SUBMITTED
  SCORING
  SCORED
  FAILED
}

enum NoteStatus {
  NEW
  REVIEWED
  MASTERED
}

enum WordTier {
  CORE          // 必修 ★★★ — must master to pass
  RECOMMENDED   // 推荐 ★★  — strongly recommended for confident pass
  EXTRA         // 拓展 ★   — extension; not required, helps high scores
}

// =============== Users + Auth (Auth.js) ===============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(STUDENT)
  locale        String    @default("zh-CN")
  activatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  ownedClasses     Class[]       @relation("TeacherClasses")
  classMemberships ClassMember[]

  tests            Test[]
  attempts         TestAttempt[]
  generationEvents GenerationEvent[]
  mistakeNotes     MistakeNote[]
  authoredComments Comment[]         @relation("CommentAuthor")
  vocabProgress    VocabProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeacherActivationCode {
  code      String    @id
  used      Boolean   @default(false)
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// =============== Classes ===============

model Class {
  id         String    @id @default(cuid())
  name       String
  teacherId  String
  inviteCode String    @unique
  examFocus  ExamType?
  createdAt  DateTime  @default(now())

  teacher     User          @relation("TeacherClasses", fields: [teacherId], references: [id])
  members     ClassMember[]
  assignments Assignment[]
  comments    Comment[]
}

model ClassMember {
  classId  String
  userId   String
  joinedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([classId, userId])
}

// =============== Exam-point & difficulty-point reference tables ===============

model ExamPoint {
  id            String   @id
  examType      ExamType
  paperCode     String
  part          Int?
  code          String
  label         String
  descriptionZh String
  skillTags     Json
  createdAt     DateTime @default(now())

  @@unique([examType, paperCode, part])
  @@index([examType])
}

model DifficultyPoint {
  id            String    @id
  examType      ExamType?
  code          String
  label         String
  descriptionZh String
  category      String
  createdAt     DateTime  @default(now())

  @@index([examType])
  @@index([category])
}

// =============== Generated content + user attempts ===============

// The generated test artifact. `payload` stores the ReadingTestResponse
// JSON from the Python agent (passage + questions + answers +
// explanations + exam_point_ids); validated on the Python side and
// re-validated Pydantic-style on the Next.js side before save.
model Test {
  id           String   @id @default(cuid())
  userId       String?
  examType     ExamType
  kind         TestKind
  part         Int?
  mode         TestMode
  difficulty   String // "A2" | "B1"
  payload      Json
  timeLimitSec Int?
  generatedBy  String // e.g. "deepseek-chat"
  createdAt    DateTime @default(now())

  // Phase 2 Listening — audio artifact state
  audioStatus          AudioStatus?
  audioR2Key           String?
  audioGenStartedAt    DateTime?
  audioGenCompletedAt  DateTime?
  audioSegments        Json?
  audioErrorMessage    String?

  // Phase 3 Speaking — per-test script + photo prompts + level tag
  speakingPrompts   Json?
  speakingPhotoKeys String[]
  speakingPersona   String?   // "KET" | "PET"

  user     User?         @relation(fields: [userId], references: [id])
  attempts TestAttempt[]

  @@index([userId, createdAt])
  @@index([examType, kind, part])
  @@index([createdAt])
}

// A user's run of a Test. Multiple attempts against the same Test = redo.
model TestAttempt {
  id            String        @id @default(cuid())
  userId        String
  testId        String
  status        AttemptStatus @default(IN_PROGRESS)
  mode          TestMode
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  answers       Json?
  rawScore      Int?
  totalPossible Int?
  scaledScore   Float?
  weakPoints    Json?

  // Phase 3 Speaking
  transcript       Json?
  rubricScores     Json?
  akoolSessionId   String?
  speakingStatus   SpeakingStatus?
  speakingError    String?

  user User @relation(fields: [userId], references: [id])
  test Test @relation(fields: [testId], references: [id])

  @@index([userId, startedAt])
  @@index([testId])
}

// =============== Mistake notes ===============

// One row per wrong question answer. Automatically created during READING
// grading. Students can walk through them at /history/mistakes and update
// status NEW -> REVIEWED -> MASTERED as they study.
model MistakeNote {
  id                String     @id @default(cuid())
  userId            String
  attemptId         String
  questionId        String
  userAnswer        String
  correctAnswer     String
  explanationZh     String?
  examPointId       String?
  difficultyPointId String?
  status            NoteStatus @default(NEW)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([attemptId])
}

// =============== Phase 4: Vocab ===============

// Cambridge wordlist source-of-truth. One row per (examType, cambridgeId).
// Source content snapshot — refreshed annually; SHA256 of source PDF
// recorded in scripts/README.md.
model Word {
  id            String    @id @default(cuid())
  examType      ExamType
  cambridgeId   String              // stable key, e.g. "ket-act-v"
  word          String              // headword as in list
  pos           String              // "adj" | "n" | "v" | "phr v" | etc.
  phonetic      String?             // IPA from EVP if available
  glossEn       String?             // Cambridge example or short EN defn
  glossZh       String              // DeepSeek-authored Chinese gloss
  example       String?             // example sentence
  topics        String[]            // appendix-2 topic tags
  tier          WordTier  @default(RECOMMENDED)
  audioKey      String?             // R2 key
  source        String              // attribution string
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vocabProgress VocabProgress[]

  @@unique([examType, cambridgeId])
  @@index([examType, tier])
  @@index([examType, topics])
}

// Per-user SRS state. mastery 0-5; nextReview drives the "due now" query.
model VocabProgress {
  id            String    @id @default(cuid())
  userId        String
  examType      ExamType
  wordId        String
  word          String              // denormalized snapshot
  mastery       Int       @default(0)
  lastReviewed  DateTime?
  nextReview    DateTime?
  reviewCount   Int       @default(0)
  correctCount  Int       @default(0)
  source        String?             // "spell" | "listen" | "assignment"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordRef Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, examType, mastery])
  @@index([userId, examType, nextReview])
}

// =============== Assignments ===============

// Teacher-created target for a class. Completion is derived from TestAttempt
// rows: a student counts as "completed" iff they have a GRADED attempt whose
// test matches (examType, kind, optional part) and whose scaledScore >=
// optional minScore. A later phase can introduce AssignmentCompletion for
// richer status (ASSIGNED / IN_PROGRESS / SUBMITTED / GRADED) and for
// marking completion manually; for Phase 1 derivation is enough.
model Assignment {
  id          String    @id @default(cuid())
  classId     String
  title       String
  description String?
  examType    ExamType
  kind        TestKind
  part        Int? // null = any part of that kind
  minScore    Int? // 0-100 scaled pass threshold; null = any graded attempt counts
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // === Phase 4 additions ===
  // VOCAB-kind only:
  targetTier       WordTier?    // null = "all tiers"
  targetWordCount  Int?         // "master >= N words from targetTier"
  // GRAMMAR-kind only (added now to avoid a second migration in slice 4b):
  targetTopicId    String?      // null = "any topic"
  // existing minScore: Int? (0-100) is reused — for GRAMMAR it's accuracy %;
  // for VOCAB use targetWordCount instead (minScore ignored).

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([classId, examType, kind])
}

// =============== Teacher -> Student comments ===============

// Short teacher note targeting one student in a class. Student views all
// received comments on /history. Phase 1 is one-way and no-unread-tracking;
// class-wide comments and student replies can be added later.
model Comment {
  id           String   @id @default(cuid())
  classId      String
  authorId     String
  targetUserId String
  body         String
  createdAt    DateTime @default(now())

  class  Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  author User  @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([targetUserId, createdAt])
  @@index([classId, targetUserId])
}

// =============== Rate limiting ===============

// Append-only log of generation calls. Rate-limit check = count rows
// where userId=? AND bucket=? AND createdAt > now() - 1 hour.
// Kept append-only (no expiry yet) — can be truncated by a cron job
// once the table gets large.
model GenerationEvent {
  id        String   @id @default(cuid())
  userId    String
  bucket    String // e.g. "reading_generate", "writing_generate"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bucket, createdAt])
}
