// Cambridge KET / PET — Prisma schema
// Phase 1, Step 11 — adds Test, TestAttempt (reading generation + attempts)
// and GenerationEvent (rate-limit counter).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============== Enums ===============

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ExamType {
  KET
  PET
}

enum TestKind {
  READING
  WRITING
  LISTENING
  SPEAKING
  MOCK_FULL
  MOCK_SECTION
}

enum TestMode {
  PRACTICE
  MOCK
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  ABANDONED
}

// =============== Users + Auth (Auth.js) ===============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(STUDENT)
  locale        String    @default("zh-CN")
  activatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  ownedClasses     Class[]       @relation("TeacherClasses")
  classMemberships ClassMember[]

  attempts         TestAttempt[]
  generationEvents GenerationEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeacherActivationCode {
  code      String    @id
  used      Boolean   @default(false)
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// =============== Classes ===============

model Class {
  id         String    @id @default(cuid())
  name       String
  teacherId  String
  inviteCode String    @unique
  examFocus  ExamType?
  createdAt  DateTime  @default(now())

  teacher User          @relation("TeacherClasses", fields: [teacherId], references: [id])
  members ClassMember[]
}

model ClassMember {
  classId  String
  userId   String
  joinedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([classId, userId])
}

// =============== Exam-point & difficulty-point reference tables ===============

model ExamPoint {
  id            String   @id
  examType      ExamType
  paperCode     String
  part          Int?
  code          String
  label         String
  descriptionZh String
  skillTags     Json
  createdAt     DateTime @default(now())

  @@unique([examType, paperCode, part])
  @@index([examType])
}

model DifficultyPoint {
  id            String    @id
  examType      ExamType?
  code          String
  label         String
  descriptionZh String
  category      String
  createdAt     DateTime  @default(now())

  @@index([examType])
  @@index([category])
}

// =============== Generated content + user attempts ===============

// The generated test artifact. `payload` stores the ReadingTestResponse
// JSON from the Python agent (passage + questions + answers +
// explanations + exam_point_ids); validated on the Python side and
// re-validated Pydantic-style on the Next.js side before save.
model Test {
  id           String   @id @default(cuid())
  examType     ExamType
  kind         TestKind
  part         Int?
  mode         TestMode
  difficulty   String // "A2" | "B1"
  payload      Json
  timeLimitSec Int?
  generatedBy  String // e.g. "deepseek-chat"
  createdAt    DateTime @default(now())

  attempts TestAttempt[]

  @@index([examType, kind, part])
  @@index([createdAt])
}

// A user's run of a Test. Multiple attempts against the same Test = redo.
model TestAttempt {
  id            String        @id @default(cuid())
  userId        String
  testId        String
  status        AttemptStatus @default(IN_PROGRESS)
  mode          TestMode
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  answers       Json?
  rawScore      Int?
  totalPossible Int?
  scaledScore   Float?
  weakPoints    Json?

  user User @relation(fields: [userId], references: [id])
  test Test @relation(fields: [testId], references: [id])

  @@index([userId, startedAt])
  @@index([testId])
}

// =============== Rate limiting ===============

// Append-only log of generation calls. Rate-limit check = count rows
// where userId=? AND bucket=? AND createdAt > now() - 1 hour.
// Kept append-only (no expiry yet) — can be truncated by a cron job
// once the table gets large.
model GenerationEvent {
  id        String   @id @default(cuid())
  userId    String
  bucket    String // e.g. "reading_generate", "writing_generate"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bucket, createdAt])
}
