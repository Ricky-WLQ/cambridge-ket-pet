# ========== apps/web ==========

# Local Postgres (provisioned via docker-compose in Step 3)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ketpet
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ketpet

# Auth.js v5 (NextAuth v5) — self-hosted, backed by our Postgres via @auth/prisma-adapter
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Optional OAuth providers (uncomment + fill if you want social login)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Internal AI service (Python FastAPI at services/ai).
# Local dev uses 8001 to avoid conflicts with other Docker projects binding 8000.
# Docker/Zeabur deployments keep port 8000 (see services/ai/Dockerfile).
INTERNAL_AI_URL=http://localhost:8001
INTERNAL_AI_SHARED_SECRET=change-me-in-dev

# ========== services/ai ==========

# DeepSeek direct API — used in Phase 1 for reading/writing generation + grading
DEEPSEEK_API_KEY=

# SiliconFlow — used in Phase 2 for CosyVoice2 TTS (Listening)
SILICONFLOW_API_KEY=

# DashScope — used in Phase 3 for Qwen3.5-Omni Realtime (Speaking)
DASHSCOPE_API_KEY=

# Must match apps/web's INTERNAL_AI_SHARED_SECRET
INTERNAL_SHARED_SECRET=change-me-in-dev

# ========== Phase 2 Listening — Cloudflare R2 ==========

# Cloudflare Account ID (32-char hex, visible on Cloudflare dashboard home / URL)
R2_ACCOUNT_ID=
# R2 API token access key (create under R2 → Manage API Tokens)
R2_ACCESS_KEY_ID=
# R2 API token secret (shown only once at creation — save it immediately)
R2_SECRET_ACCESS_KEY=
# R2 bucket name that stores generated listening audio (pre-created in console)
R2_BUCKET=cambridge-ket-pet-audio
# S3-compatible endpoint. Replace <accountId> with your R2_ACCOUNT_ID value.
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com

# ========== Phase 2 Listening — runtime caps ==========

# "auto" uses the bundled ffmpeg-static binary; set to an absolute path to
# override for Zeabur or CI if the bundled binary is unavailable.
FFMPEG_BINARY=auto

# Max concurrent audio-generation jobs per Zeabur instance (prevents CPU saturation)
LISTENING_MAX_CONCURRENT=3
# Max jobs waiting beyond the concurrent cap; requests past this return 503
LISTENING_QUEUE_MAX=5
# Stale-state timeout in ms: cron reaper marks GENERATING jobs as FAILED after this (default 5 min)
LISTENING_GEN_TIMEOUT_MS=300000
# Per-user hourly rate limit for listening generation (counts both success + failure)
LISTENING_RATE_LIMIT_PER_HOUR=10
# Per-generation parallel edge-tts segment synthesis count (Task 27.5 perf tuning)
LISTENING_SEGMENT_CONCURRENCY=4
# Mock-mode total clock in seconds: 30 min matches Cambridge KET/PET spec §2.3
LISTENING_TIME_LIMIT_SEC=1800
# Post-deadline submit grace window in ms (AB testing pattern): 1 min
LISTENING_GRACE_PERIOD_MS=60000

# ========== Cron ==========

# Shared secret for the /api/cron/* endpoints. Long random string; the
# scheduler must send it in the `x-cron-secret` header.
CRON_SECRET=
