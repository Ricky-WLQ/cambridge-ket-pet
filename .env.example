# ========== apps/web ==========

# Local Postgres (provisioned via docker-compose in Step 3)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ketpet
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ketpet

# Auth.js v5 (NextAuth v5) — self-hosted, backed by our Postgres via @auth/prisma-adapter
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Optional OAuth providers (uncomment + fill if you want social login)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Internal AI service (Python FastAPI at services/ai).
# Local dev uses 8001 to avoid conflicts with other Docker projects binding 8000.
# Docker/Zeabur deployments keep port 8000 (see services/ai/Dockerfile).
INTERNAL_AI_URL=http://localhost:8001
INTERNAL_AI_SHARED_SECRET=change-me-in-dev

# ========== services/ai ==========

# DeepSeek direct API — used in Phase 1 for reading/writing generation + grading
DEEPSEEK_API_KEY=

# SiliconFlow — used in Phase 2 for CosyVoice2 TTS (Listening)
SILICONFLOW_API_KEY=

# DashScope — used in Phase 3 for Qwen3.5-Omni Realtime (Speaking)
DASHSCOPE_API_KEY=

# Must match apps/web's INTERNAL_AI_SHARED_SECRET
INTERNAL_SHARED_SECRET=change-me-in-dev

# ========== Phase 2 Listening ==========

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cambridge-ket-pet-audio
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com

# ffmpeg
FFMPEG_BINARY=auto

# Listening runtime
LISTENING_MAX_CONCURRENT=3
LISTENING_QUEUE_MAX=5
LISTENING_GEN_TIMEOUT_MS=300000
LISTENING_RATE_LIMIT_PER_HOUR=10
LISTENING_TIME_LIMIT_SEC=1800
LISTENING_GRACE_PERIOD_MS=60000
